[sub_resource type="GDScript" id="GDScript_ll2xe"]
resource_name = "StartButton"
script/source = "extends Button


var start_match: Callable

func _on_pressed() -> void:
	assert(start_match.is_valid(), \"Start action not properly assigned\")
	start_match.call()
"

[sub_resource type="GDScript" id="GDScript_4dhkl"]
resource_name = "PlayerList"
script/source = "extends ItemList


func _ready() -> void:
	multiplayer.peer_connected.connect(update_player_list.unbind(1))
	multiplayer.peer_disconnected.connect(update_player_list.unbind(1))

func update_player_list() -> void:
	var player_ids: PackedInt32Array = multiplayer.get_peers()
	player_ids.append(multiplayer.get_unique_id())
	player_ids.sort()
	
	
	clear()
	
	for id in player_ids:
		add_item(str(id))
"

